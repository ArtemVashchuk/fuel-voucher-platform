# Database Configuration
DATABASE_URL=postgresql://postgres:password@admin-database:5432/fuel_db

# Monobank Configuration
MONOBANK_API_TOKEN=your_test_token_from_api_monobank_ua
MONOBANK_WEBHOOK_URL=https://your-public-url/api/monobank/webhook

# Gemini AI (Optional - for voucher OCR)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5001

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
