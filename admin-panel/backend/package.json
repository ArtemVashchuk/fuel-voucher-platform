{
  "name": "admin-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outdir=dist --external:better-sqlite3 --external:pg-native --external:canvas --external:sharp --external:@google/generative-ai --external:jsqr --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "npm run db:push && node dist/index.js",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "canvas": "^2.11.2",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "ioredis": "^5.9.2",
    "jsqr": "^1.4.0",
    "memorystore": "^1.6.7",
    "multer": "^2.0.2",
    "node-fetch": "^2.7.0",
    "openai": "^6.15.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.2.0",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.16.3",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.33.2",
    "stripe": "^20.1.2",
    "twilio": "^5.11.2",
    "unzipper": "^0.12.3",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.0",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.5",
    "@types/sinon": "^21.0.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.4",
    "sinon": "^21.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.20.5",
    "typescript": "5.6.3",
    "vitest": "^4.0.18"
  }
}
