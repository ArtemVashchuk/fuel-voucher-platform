{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": ["https://fuel-flow-opal.vercel.app"]
  },
  "Twilio": {
    "AccountSid": "your_production_account_sid_here",
    "AuthToken": "your_production_auth_token_here",
    "PhoneNumber": "+1234567890"
  },
  "Jwt": {
    "Secret": "CHANGE_THIS_TO_A_SECURE_RANDOM_KEY_IN_PRODUCTION_AT_LEAST_32_CHARACTERS",
    "Issuer": "FuelFlow",
    "Audience": "FuelFlow",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Monobank": {
    "Token": "PRODUCTION_TOKEN_FROM_MONOBANK_API",
    "WebhookUrl": "https://api.fuelflow.com/api/monobank/webhook",
    "BaseUrl": "https://api.monobank.ua",
    "PublicKey": "-----BEGIN PUBLIC KEY-----\nPRODUCTION_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----",
    "Enabled": true,
    "RedirectUrl": "https://fuelflow.com/payment-result"
  },
  "DeviceAuth": {
    "Enabled": true,
    "ChallengeExpirySeconds": 30,
    "SignatureNonceTtlSeconds": 60,
    "TimestampToleranceMs": 300000,
    "AllowDevelopmentBypass": false,
    "RequireSignatureForEndpoints": [
      "/api/orders/checkout"
    ]
  }
}
