      "item": [
        {
          "name": "Register Device",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{baseUrl}}/api/auth/device/register",
            "body": { "mode": "raw", "raw": "{\n  \"deviceId\": \"test-device-001\",\n  \"publicKey\": \"MFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAE...\",\n  \"deviceModel\": \"iPhone 15\",\n  \"osVersion\": \"iOS 17.0\",\n  \"appVersion\": \"1.0.0\"\n}" }
          }
        },
        {
          "name": "Generate Challenge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/device/challenge",
            "body": { "mode": "raw", "raw": "{\n  \"deviceId\": \"test-device-001\"\n}" }
          }
        },
        {
          "name": "Verify Challenge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/device/verify",
            "body": { "mode": "raw", "raw": "{\n  \"deviceId\": \"test-device-001\",\n  \"challenge\": \"<challenge-from-generate-step>\",\n  \"signature\": \"<hmac-signature>\"\n}" }
          }
        },
        {
          "name": "Logout Device",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/auth/device/logout"
          }
        }
      ]
